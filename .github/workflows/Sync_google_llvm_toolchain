name: Sync llvm-project
on:
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Mirror repo
        uses: pixta-dev/repository-mirroring-action@v1
        with:
          target_repo_url: git@github.com:kquieter-debug/Save_android_llvm_toolchain.git
          ssh_private_key: ${{ secrets.GITHUB_TOKEN }}
          source_repo_url: https://android.googlesource.com/toolchain/llvm-project